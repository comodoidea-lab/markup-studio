    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.14.0"
  }
